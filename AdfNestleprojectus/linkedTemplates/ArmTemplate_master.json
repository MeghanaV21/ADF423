{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "AdfNestleprojectus"
		},
		"LS_LKUP_MAX_VALUE_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_LKUP_MAX_VALUE'"
		},
		"LS_ONPREM_SQLSERVER_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_ONPREM_SQLSERVER'"
		},
		"LS_SQLTABLE_PARQUET_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_SQLTABLE_PARQUET'"
		},
		"LS_SQL_MIGRATION_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_SQL_MIGRATION'"
		},
		"LS_LKUP_MAX_VALUE_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "."
		},
		"LS_LKUP_MAX_VALUE_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sqlmigration"
		},
		"LS_LKUP_MAX_VALUE_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "Meghana"
		},
		"LS_ONPREM_SQLSERVER_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "."
		},
		"LS_ONPREM_SQLSERVER_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sqlmigration"
		},
		"LS_ONPREM_SQLSERVER_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "Meghana"
		},
		"LS_SQLTABLE_PARQUET_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdevnestleprojectus.dfs.core.windows.net/"
		},
		"LS_SQL_MIGRATION_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "."
		},
		"LS_SQL_MIGRATION_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sqlmigration"
		},
		"LS_SQL_MIGRATION_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "Meghana"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "AdfNestleprojectus_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_LKUP_MAX_VALUE_password": {
						"value": "[parameters('LS_LKUP_MAX_VALUE_password')]"
					},
					"LS_ONPREM_SQLSERVER_password": {
						"value": "[parameters('LS_ONPREM_SQLSERVER_password')]"
					},
					"LS_SQLTABLE_PARQUET_accountKey": {
						"value": "[parameters('LS_SQLTABLE_PARQUET_accountKey')]"
					},
					"LS_SQL_MIGRATION_password": {
						"value": "[parameters('LS_SQL_MIGRATION_password')]"
					},
					"LS_LKUP_MAX_VALUE_properties_typeProperties_server": {
						"value": "[parameters('LS_LKUP_MAX_VALUE_properties_typeProperties_server')]"
					},
					"LS_LKUP_MAX_VALUE_properties_typeProperties_database": {
						"value": "[parameters('LS_LKUP_MAX_VALUE_properties_typeProperties_database')]"
					},
					"LS_LKUP_MAX_VALUE_properties_typeProperties_userName": {
						"value": "[parameters('LS_LKUP_MAX_VALUE_properties_typeProperties_userName')]"
					},
					"LS_ONPREM_SQLSERVER_properties_typeProperties_server": {
						"value": "[parameters('LS_ONPREM_SQLSERVER_properties_typeProperties_server')]"
					},
					"LS_ONPREM_SQLSERVER_properties_typeProperties_database": {
						"value": "[parameters('LS_ONPREM_SQLSERVER_properties_typeProperties_database')]"
					},
					"LS_ONPREM_SQLSERVER_properties_typeProperties_userName": {
						"value": "[parameters('LS_ONPREM_SQLSERVER_properties_typeProperties_userName')]"
					},
					"LS_SQLTABLE_PARQUET_properties_typeProperties_url": {
						"value": "[parameters('LS_SQLTABLE_PARQUET_properties_typeProperties_url')]"
					},
					"LS_SQL_MIGRATION_properties_typeProperties_server": {
						"value": "[parameters('LS_SQL_MIGRATION_properties_typeProperties_server')]"
					},
					"LS_SQL_MIGRATION_properties_typeProperties_database": {
						"value": "[parameters('LS_SQL_MIGRATION_properties_typeProperties_database')]"
					},
					"LS_SQL_MIGRATION_properties_typeProperties_userName": {
						"value": "[parameters('LS_SQL_MIGRATION_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}