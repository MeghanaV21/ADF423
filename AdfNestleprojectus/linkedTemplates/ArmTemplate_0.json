			"type": "string",
			"defaultValue": "."
		},
		"LS_ON_PREM_SQL_SERVER_DW_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sqlmigration"
		},
		"LS_ON_PREM_SQL_SERVER_DW_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "Meghana"
